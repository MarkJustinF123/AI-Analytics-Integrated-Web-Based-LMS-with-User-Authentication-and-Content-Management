{
  "kind": "collectionType",
  "collectionName": "assignments",
  "info": {
    "singularName": "assignment",
    "pluralName": "assignments",
    "displayName": "Assignment"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "instructions": {
      "type": "text"
    },
    "files": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "course": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::course.course"
    },
    "duedate": {
      "type": "date"
    }
  }
}
